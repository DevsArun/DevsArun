# ============================================================
# WhatsApp CRM Engine - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server Configuration
PORT=3001
NODE_ENV=production

# API Security - Generate a strong random key
API_KEY=your_strong_api_key_here_min_32_chars

# PHP Webhook Configuration (Hostinger)
WEBHOOK_URL=https://yourdomain.com/webhook.php
WEBHOOK_SECRET=your_webhook_hmac_secret_here

# Socket.io Configuration
SOCKET_CORS_ORIGIN=https://yourdomain.com

# WhatsApp Session
SESSION_NAME=wa-crm-session

# Logging
LOG_LEVEL=info
